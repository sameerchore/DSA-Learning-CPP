class Solution {
public:
    vector<int> leftRightDifference(vector<int>& nums) {
        long long leftSum=0;
        long long TotSum=0;
        int temp=0;
        for(int x:nums){
            TotSum+=x;
        }
        // cout<<TotSum;
        for(int i=0;i<nums.size();i++){
            leftSum+=temp;
            temp=nums[i];
            nums[i]=abs(TotSum-nums[i]-2*leftSum);
        }
        return nums;
    }
};