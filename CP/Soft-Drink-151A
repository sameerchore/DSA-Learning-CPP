// Thus from the above drink per person will be the minimum of drink, lime and salt divided by n.

// here n is the number of friends, k is the number of bottles, l is the volume of each bottle, c is the number of limes, d is the number of slices per lime, p is the amount of salt in grams, nl is the amount of drink needed for one person, and np is the amount of salt needed for one person.
#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, k, l, c, d, p, nl, np;
    cin >> n >> k >> l >> c >> d >> p >> nl >> np;

    int drink = (k * l) / nl;
    int lime  = c * d;
    int salt  = p / np;

    cout << min({drink, lime, salt}) / n;

    return 0;
}