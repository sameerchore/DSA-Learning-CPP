
class Solution {
public:
    int getDecimalValue(ListNode* head) {
        long long dec=0;
        ListNode* temp=head;
        ListNode* prev=nullptr;
        
        while(temp){
            ListNode* nextNode=temp->next;
            temp->next=prev;
            prev=temp;
            temp=nextNode;
        }
        int i=1;
        while(prev){
            dec+=prev->val*i;
            prev=prev->next;
            i=2*i;
        }
        return dec;
    }
};


